# PostgreSQL
POSTGRES_USER=bensoneria
POSTGRES_PASSWORD=bensoneria_dev
POSTGRES_DB=labensoneria

# Backend
DATABASE_URL=postgresql://bensoneria:bensoneria_dev@localhost:5432/labensoneria
JWT_SECRET=cambia_esto_en_produccion
JWT_EXPIRES_IN=7d
PORT=3000
CORS_ORIGINS=http://localhost:5173

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe (Fase 5)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
FRONTEND_URL=http://localhost:5173

# Frontend
VITE_API_URL=http://localhost:3000
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Resend (emails)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="La Bensonería <noreply@labensoneria.xyz>"

# Packlink Pro (envíos)
PACKLINK_API_KEY=
PACKLINK_API_URL=https://api.packlink.com
SHIPPING_VAT_MULTIPLIER=1.21
# Datos del remitente (taller)
SHIPPER_NAME=La Bensonería
SHIPPER_STREET=
SHIPPER_CITY=
SHIPPER_ZIP=
SHIPPER_COUNTRY=ES
SHIPPER_PHONE=
SHIPPER_EMAIL=
# Dimensiones por defecto del paquete (cm)
SHIPPER_BOX_H_CM=15
SHIPPER_BOX_W_CM=20
SHIPPER_BOX_L_CM=25

# Admin inicial (solo para seed)
ADMIN_EMAIL=admin@labensoneria.com
ADMIN_PASSWORD=cambia_esto
